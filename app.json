{
  "expo": {
    "name": "CARE Mobile",
    "slug": "care-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0a7fb8",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.care.nursing",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a7fb8"
      },
      "package": "com.care.nursing",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#0a7fb8",
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new notifications"
    },
    "platforms": ["ios", "android"],
    "extra": {
      "eas": {
        "projectId": "36c20da6-6d6d-4287-b885-d03988aa187d"
      }
    }
  }
}
