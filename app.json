{
  "expo": {
    "name": "876Nurses",
    "slug": "876nurses",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Images/Nurses-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Images/Nurses-icon.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nurses876.home",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Images/Nurses-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.nurses876.home",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "notification": {
      "icon": "./assets/Images/Nurses-icon.png",
      "color": "#8B0000",
      "androidMode": "default",
      "androidCollapsedTitle": "#{unread_notifications} new notifications"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "favicon": "./assets/Images/Nurses-icon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "9e3794a4-ec1e-48bc-9199-2e8ff5ab418d"
      }
    },
    "owner": "kadian"
  }
}
