rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
              get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'superAdmin');
    }

    // Helper function to check if user is a nurse (nurses/{uid} exists)
    function isNurse() {
      return isAuthenticated() && exists(/databases/$(database)/documents/nurses/$(request.auth.uid));
    }

    // Helper: allow invoice creation if the authenticated user is the assigned nurse
    // for the referenced shift request.
    function isAssignedNurseForShift(shiftRequestId) {
      return isAuthenticated() &&
        shiftRequestId != null &&
        (
          get(/databases/$(database)/documents/shiftRequests/$(shiftRequestId)).data.nurseUid == request.auth.uid ||
          get(/databases/$(database)/documents/shiftRequests/$(shiftRequestId)).data.primaryNurseId == request.auth.uid ||
          get(/databases/$(database)/documents/shiftRequests/$(shiftRequestId)).data.assignedNurseId == request.auth.uid
        );
    }
    
    // Services collection - readable by anyone, writable by admins
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Profile edit requests collection
    match /profileEditRequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.nurseId);
      allow delete: if isAdmin();
    }
    
    // Profile edit requests collection (lowercase variant)
    match /profileeditrequests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.nurseId);
      allow delete: if isAdmin();
    }
    
    // Users collection
    match /users/{userId} {
      // Allow public read so pre-login flows (username lookup, onboarding content) keep working
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Nurses collection
    match /nurses/{nurseId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == nurseId);
      allow delete: if isAdmin();
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.patientId || 
        request.auth.uid == resource.data.nurseId || 
        request.auth.uid == resource.data.assignedNurseId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Shift requests collection
    match /shiftRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();

      // Allow admins full control.
      allow write: if isAdmin();

      // Allow nurses to CREATE invoices they generated from the mobile app.
      // Updates/deletes remain admin-only to avoid tampering.
      allow create: if isAuthenticated() &&
        request.resource.data.createdByUid == request.auth.uid &&
        (isNurse() || isAssignedNurseForShift(request.resource.data.shiftRequestId));
      allow update, delete: if isAdmin();
    }

    // Counters collection (used for invoice numbering)
    match /counters/{counterId} {
      // Allow authenticated reads so the client can attempt to use the shared counter.
      allow read: if isAuthenticated();

      // Only admins can seed/create counters.
      allow create, delete: if isAdmin();

      // Allow strict increment updates for the nurse invoice counter.
      allow update: if isAdmin() || (
        isAuthenticated() &&
        counterId == 'nurseInvoiceNumber' &&
        (resource.data.sequence is int) &&
        (request.resource.data.sequence is int) &&
        request.resource.data.sequence == resource.data.sequence + 1 &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['sequence', 'updatedAt'])
      );
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if isAdmin();
    }
    
    // Store products collection
    match /storeProducts/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Store orders collection
    match /storeOrders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isAdmin());
      allow delete: if isAdmin();
    }

    // Patients collection (used for admin client selectors)
    match /patients/{patientId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Payslips collection
    match /payslips/{payslipId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Payment settings collection
    match /paymentSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
