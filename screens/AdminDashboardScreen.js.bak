      if (!result.canceled && result.assets && result.assets[0]) {
        setNurseIdPhoto(result.assets[0]);
      }
    } catch (error) {
      console.error('Error picking nurse ID photo:', error);
      Alert.alert('Error', 'Failed to select photo. Please try again.');
