import AsyncStorage from '@react-native-async-storage/async-storage';
import { Platform } from 'react-native';
import * as Device from 'expo-device';

// Production API URL - Replace with your deployed backend URL
const BASE_URL = __DEV__ 
  ? 'http://10.5.0.238:5000/api' // Development (local) - has ADMIN001 support
  : 'https://shielded-coast-08850-f496a70eafdb.herokuapp.com/api'; // Production (Heroku)

class ApiService {
  static isOffline = false; // Track offline status to reduce log spam
  static lastOfflineCheck = 0; // Timestamp of last offline check
  static OFFLINE_CHECK_INTERVAL = 30000; // Check every 30 seconds
  static consecutiveFailures = 0; // Track consecutive failures
  static FAILURE_THRESHOLD = 3; // Mark offline after 3 consecutive failures
  
  // Throttle shift request calls
  static lastShiftRequestCall = 0;
  static SHIFT_REQUEST_THROTTLE = 0; // Disable throttle for debugging
  
  static async getAuthToken() {
    try {
      // Try to get the auth token saved during login
      const authToken = await AsyncStorage.getItem('authToken');
      if (authToken) {
        // Removed excessive logging
        return authToken;
      }

      // Fallback: Try to get Firebase token
      const firebaseToken = await AsyncStorage.getItem('firebaseToken');
      if (firebaseToken) {
        return firebaseToken;
      }

      return null;
    } catch (error) {
      return null;
    }
  }

  static async makeRequest(endpoint, options = {}) {
    try {
      // Skip API calls only if we're definitely offline (multiple consecutive failures)
      const now = Date.now();
      if (this.isOffline && (now - this.lastOfflineCheck) < this.OFFLINE_CHECK_INTERVAL) {
        throw new Error('API offline - using cached data');
      }

      const token = await this.getAuthToken();
      
      // If no token and endpoint requires authentication, return empty result
      if (!token && !endpoint.includes('/auth/login') && !endpoint.includes('/auth/register')) {
        // No auth token for this endpoint - skipping API call
        return { success: true, data: [], items: [], shiftRequests: [], appointments: [], invoices: [] };
      }
      
      const config = {
        headers: {
          'Content-Type': 'application/json',
          ...(token && { Authorization: `Bearer ${token}` }),
          ...options.headers,
        },
        ...options,
      };

      const fullUrl = `${BASE_URL}${endpoint}`;
      
      const response = await fetch(fullUrl, config);
      const data = await response.json();

      if (!response.ok) {
        console.error(`API Error ${response.status}:`, data);
        throw new Error(data.error || data.message || `HTTP error! status: ${response.status}`);
      }

      // Reset failure counter on successful request
      this.consecutiveFailures = 0;

      // Mark as online if request succeeds
      if (this.isOffline) {
        // Backend connection restored
        this.isOffline = false;
      }

      return data;
    } catch (error) {
      // Only count network/connection errors as consecutive failures
      // Don't count 403/401/400 errors as they indicate request issues, not connectivity
      const status = error.status || error.response?.status;
      const isConnectionError = !status || (status >= 500) || error.message?.includes('fetch');
      
      if (isConnectionError) {
        this.consecutiveFailures++;
        
        // Only mark as offline after multiple consecutive failures
        if (this.consecutiveFailures >= this.FAILURE_THRESHOLD && !this.isOffline) {
          this.isOffline = true;
          this.lastOfflineCheck = Date.now();
        }
      } else {
        // Reset failure counter for non-connection errors
        if (this.consecutiveFailures > 0) {
          // Connection restored after request error
          this.consecutiveFailures = 0;
        }
      }
      
      throw error;
    }
  }

