# Server Configuration
PORT=3000
NODE_ENV=development
API_KEY=your-secure-api-key-here-change-this

# CORS Settings (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:19000,http://localhost:19001,http://localhost:19002

# Gmail OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_from_google_cloud.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=REDACTED
GMAIL_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Gmail Refresh Token (obtain through OAuth flow - see setup-oauth.js script)
GMAIL_REFRESH_TOKEN=REDACTED

# Gmail Account
GMAIL_ACCOUNT=876nurses@gmail.com

# Fygaro Payment Gateway
FYGARO_API_KEY=REDACTED
FYGARO_API_SECRET=REDACTED
FYGARO_BASE_URL=https://www.fygaro.com/api/v1
FYGARO_TEST_MODE=true

# Safety switches
# Keep these OFF until you've implemented webhook signature verification and
# stricter matching to prevent fraudulent "paid" stamping.
ENABLE_FYGARO_WEBHOOK_UPDATES=false
ENABLE_FYGARO_SYNC=false

# Firebase Admin (for scheduled jobs)
FIREBASE_SERVICE_ACCOUNT_PATH=../firebase-service-key.json
FIREBASE_ADMIN_DATABASE_URL=https://nurses-afb7e.firebaseio.com

# Overdue invoice scheduler
ENABLE_OVERDUE_CRON=true
OVERDUE_CRON_SCHEDULE=0 12 * * *
OVERDUE_CRON_TIMEZONE=America/Jamaica
RUN_OVERDUE_CRON_ON_BOOT=false
